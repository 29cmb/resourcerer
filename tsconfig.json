{
  "compilerOptions": {
    "target": "ES6",
    "allowJs": true,
    "module": "nodenext",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
  },
  "include": ["src/**/*"]
}
